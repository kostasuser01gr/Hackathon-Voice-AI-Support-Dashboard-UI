# Required: Gemini API key used server-side only.
GEMINI_API_KEY=your_gemini_api_key

# Optional: public URL for links/callbacks in deployment
APP_BASE_URL=http://localhost:3000

# History persistence mode: local (default) or db
HISTORY_MODE=local

# Requests per IP per minute for /api/process
RATE_LIMIT_PER_MIN=20

# Max transcript chars accepted by /api/process
MAX_INPUT_CHARS=2000

# Required only when HISTORY_MODE=db
DATABASE_URL=postgres://user:pass@host:5432/dbname
