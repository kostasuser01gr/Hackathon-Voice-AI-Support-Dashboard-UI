# Required: Gemini API key used server-side only.
GEMINI_API_KEY=your_gemini_api_key

# Optional: public URL for links/callbacks in deployment
APP_BASE_URL=http://localhost:3000

# History persistence mode: local (default) or db
HISTORY_MODE=local

# Requests per IP per minute for /api/process
RATE_LIMIT_PER_MIN=20

# Burst requests per client key in 10s window
RATE_LIMIT_BURST_PER_10S=6

# Max transcript chars accepted by /api/process
MAX_INPUT_CHARS=2000

# Prompt registry version
PROMPT_VERSION=v1

# Enable deterministic local fallback for demos when Gemini is unavailable
DEMO_SAFE_MODE=false

# Wave 1 endpoint gate
FEATURE_WAVE1=true

# Grounding verifier policy: warn | repair | reject
VERIFIER_POLICY=warn

# Integrations execution mode: mock | live
INTEGRATIONS_MODE=mock

# Optional share-link signing secret
SHARE_TOKEN_SECRET=replace-with-random-string

# Optional session cookie signing secret (recommended in production)
SESSION_SIGNING_SECRET=replace-with-another-random-string

# Optional cap for local history sessions (client-side)
NEXT_PUBLIC_MAX_LOCAL_SESSIONS=25

# Required only when HISTORY_MODE=db
DATABASE_URL=postgres://user:pass@host:5432/dbname
