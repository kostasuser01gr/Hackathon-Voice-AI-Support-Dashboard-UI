# Required: Gemini API key used server-side only.
GEMINI_API_KEY=your_gemini_api_key

# Optional: public URL for links/callbacks in deployment
APP_BASE_URL=http://localhost:3000

# History persistence mode: local (default) or db
HISTORY_MODE=local

# Requests per IP per minute for /api/process
RATE_LIMIT_PER_MIN=20

# Burst requests per client key in 10s window
RATE_LIMIT_BURST_PER_10S=6

# Max transcript chars accepted by /api/process
MAX_INPUT_CHARS=2000

# Prompt registry version
PROMPT_VERSION=v1

# Enable deterministic local fallback for demos when Gemini is unavailable
DEMO_SAFE_MODE=false

# Wave 1 endpoint gate
FEATURE_WAVE1=true

# Grounding verifier policy: warn | repair | reject
VERIFIER_POLICY=warn

# Integrations execution mode: mock | live
INTEGRATIONS_MODE=mock

# Runtime state adapter: memory | redis
RUNTIME_STATE_MODE=memory

# Required when RUNTIME_STATE_MODE=redis
REDIS_URL=redis://localhost:6379

# Optional share-link signing secret
SHARE_TOKEN_SECRET=replace-with-random-string

# Share-link hardening
SHARE_TOKEN_TTL_MS=604800000
SHARE_TOKEN_REQUIRE_PASSWORD=false

# Optional session cookie signing secret (recommended in production)
SESSION_SIGNING_SECRET=replace-with-another-random-string

# Session hardening
REQUIRE_SIGNED_SESSION_IN_PROD=true
ALLOW_HEADER_SESSION_FALLBACK_IN_PROD=false

# Mutation replay protection
MUTATION_IDEMPOTENCY_REQUIRED=false

# API v2 rollout
FEATURE_V2_APIS=true

# Gemini resilience
SECONDARY_GEMINI_MODEL=
GEMINI_TIMEOUT_MS=10000
GEMINI_BREAKER_FAILURE_THRESHOLD=5
GEMINI_BREAKER_COOLDOWN_MS=30000

# Optional cap for local history sessions (client-side)
NEXT_PUBLIC_MAX_LOCAL_SESSIONS=25

# Runtime guardian monitor (background health model)
GUARDIAN_ENABLED=true
GUARDIAN_INTERVAL_MS=10000

# Security shield thresholds
SECURITY_BLOCK_MINUTES=5
SECURITY_RISK_THRESHOLD=100

# Required only when HISTORY_MODE=db
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Optional Cloud Tasks worker integration
CLOUD_TASKS_QUEUE=
CLOUD_TASKS_LOCATION=

# Optional workspace allowlist for canary rollouts
CANARY_WORKSPACE_ALLOWLIST=
